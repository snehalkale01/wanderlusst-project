script.js

function chatbotResponse(message) {

    message = message.toLowerCase();

    if (message.includes("hello") || message.includes("hi")) {
        return "Hello! Welcome to Customer Support.";
    }

    else if (message.includes("product")) {
        return "We have mobiles, laptops, and accessories.";
    }

    else if (message.includes("price")) {
        return "Please mention the product name.";
    }

    else if (message.includes("order")) {
        return "Your order will be delivered within 3-5 days.";
    }

    else if (message.includes("return")) {
        return "Return policy is available for 7 days.";
    }

    else if (message.includes("refund")) {
        return "Refund will be processed within 5 working days.";
    }

    else if (message.includes("contact")) {
        return "You can contact us at support@gmail.com";
    }

    else if (message.includes("bye")) {
        return "Thank you! Visit again.";
    }

    else {
        return "Sorry, I didn't understand.";
    }
}

function sendMessage() {

    let userInput = document.getElementById("userInput").value;

    if (userInput.trim() === "") {
        return;
    }

    let chatbox = document.getElementById("chatbox");

    // Display user message
    chatbox.innerHTML += "<p><b>You:</b> " + userInput + "</p>";

    // Get bot response
    let botReply = chatbotResponse(userInput);

    // Display bot response
    chatbox.innerHTML += "<p><b>Bot:</b> " + botReply + "</p>";

    // Clear input
    document.getElementById("userInput").value = "";

    // Auto scroll
    chatbox.scrollTop = chatbox.scrollHeight;
}



