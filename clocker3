// Advanced Hospital Expert System with Patient Scheduling
#include <iostream>
using namespace std;

struct Patient
{
    string name;
    int age;
    string symptom;
    int priority;
    string disease;
    string doctor;
    string test;
    string room;
};

int main()
{
    int n;

    cout << "===========================================";
    cout << "\n     HOSPITAL EXPERT SYSTEM";
    cout << "\n===========================================";

    cout << "\n\nEnter number of patients: ";
    cin >> n;

    Patient p[20];

    // Input Patient Details
    for(int i = 0; i < n; i++)
    {
        cout << "\n===================================";
        cout << "\nEnter Details of Patient " << i + 1;
        cout << "\n===================================";

        cout << "\nEnter Patient Name: ";
        cin >> p[i].name;

        cout << "Enter Age: ";
        cin >> p[i].age;

        cout << "Enter Symptom ";
        cout << "(fever/cold/headache/chestpain/stomachpain): ";
        cin >> p[i].symptom;

        // Expert System Rules
        if(p[i].symptom == "fever")
        {
            p[i].disease = "Viral Fever";
            p[i].doctor = "General Physician";
            p[i].test = "Blood Test";
            p[i].priority = 2;
            p[i].room = "General Ward";
        }

        else if(p[i].symptom == "cold")
        {
            p[i].disease = "Common Cold";
            p[i].doctor = "ENT Specialist";
            p[i].test = "Temperature Check";
            p[i].priority = 3;
            p[i].room = "OPD";
        }

        else if(p[i].symptom == "headache")
        {
            p[i].disease = "Migraine";
            p[i].doctor = "Neurologist";
            p[i].test = "MRI Scan";
            p[i].priority = 2;
            p[i].room = "Observation Room";
        }

        else if(p[i].symptom == "chestpain")
        {
            p[i].disease = "Heart Problem";
            p[i].doctor = "Cardiologist";
            p[i].test = "ECG";
            p[i].priority = 1;
            p[i].room = "ICU";
        }

        else if(p[i].symptom == "stomachpain")
        {
            p[i].disease = "Acidity";
            p[i].doctor = "Gastroenterologist";
            p[i].test = "Stomach Checkup";
            p[i].priority = 2;
            p[i].room = "General Ward";
        }

        else
        {
            p[i].disease = "Unknown";
            p[i].doctor = "General Physician";
            p[i].test = "General Checkup";
            p[i].priority = 3;
            p[i].room = "OPD";
        }
    }

    // Priority Scheduling
    for(int i = 0; i < n - 1; i++)
    {
        for(int j = i + 1; j < n; j++)
        {
            if(p[j].priority < p[i].priority)
            {
                swap(p[i], p[j]);
            }
        }
    }

    // Display Final Report
    cout << "\n\n===========================================";
    cout << "\n       PATIENT TREATMENT SCHEDULE";
    cout << "\n===========================================";

    for(int i = 0; i < n; i++)
    {
        cout << "\n\nPatient Number : " << i + 1;

        cout << "\nPatient Name   : " << p[i].name;

        cout << "\nAge            : " << p[i].age;

        cout << "\nSymptom        : " << p[i].symptom;

        cout << "\nDisease        : " << p[i].disease;

        cout << "\nDoctor         : " << p[i].doctor;

        cout << "\nRecommended Test : " << p[i].test;

        cout << "\nAssigned Room  : " << p[i].room;

        if(p[i].priority == 1)
        {
            cout << "\nPriority Level : Emergency";
        }

        else if(p[i].priority == 2)
        {
            cout << "\nPriority Level : Serious";
        }

        else
        {
            cout << "\nPriority Level : Normal";
        }

        cout << "\n---------------------------------------";
    }

    cout << "\n\nEmergency patients are treated first.";
    cout << "\nScheduling completed successfully.";

    return 0;
}

