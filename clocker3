# Advanced Hospital Expert System with Patient Scheduling

print("===========================================")
print("     HOSPITAL EXPERT SYSTEM")
print("===========================================")

n = int(input("\nEnter number of patients: "))

patients = []

# Input Patient Details
for i in range(n):

    print("\n===================================")
    print("Enter Details of Patient", i + 1)
    print("===================================")

    name = input("\nEnter Patient Name: ")

    age = int(input("Enter Age: "))

    symptom = input(
        "Enter Symptom "
        "(fever/cold/headache/chestpain/stomachpain): "
    )

    # Expert System Rules

    if symptom == "fever":

        disease = "Viral Fever"
        doctor = "General Physician"
        test = "Blood Test"
        priority = 2
        room = "General Ward"

    elif symptom == "cold":

        disease = "Common Cold"
        doctor = "ENT Specialist"
        test = "Temperature Check"
        priority = 3
        room = "OPD"

    elif symptom == "headache":

        disease = "Migraine"
        doctor = "Neurologist"
        test = "MRI Scan"
        priority = 2
        room = "Observation Room"

    elif symptom == "chestpain":

        disease = "Heart Problem"
        doctor = "Cardiologist"
        test = "ECG"
        priority = 1
        room = "ICU"

    elif symptom == "stomachpain":

        disease = "Acidity"
        doctor = "Gastroenterologist"
        test = "Stomach Checkup"
        priority = 2
        room = "General Ward"

    else:

        disease = "Unknown"
        doctor = "General Physician"
        test = "General Checkup"
        priority = 3
        room = "OPD"

    # Store Patient Details
    patient = {
        "name": name,
        "age": age,
        "symptom": symptom,
        "disease": disease,
        "doctor": doctor,
        "test": test,
        "priority": priority,
        "room": room
    }

    patients.append(patient)

# Priority Scheduling
patients.sort(key=lambda x: x["priority"])

# Display Final Report

print("\n\n===========================================")
print("       PATIENT TREATMENT SCHEDULE")
print("===========================================")

for i in range(n):

    print("\n\nPatient Number :", i + 1)

    print("Patient Name   :", patients[i]["name"])

    print("Age            :", patients[i]["age"])

    print("Symptom        :", patients[i]["symptom"])

    print("Disease        :", patients[i]["disease"])

    print("Doctor         :", patients[i]["doctor"])

    print("Recommended Test :", patients[i]["test"])

    print("Assigned Room  :", patients[i]["room"])

    if patients[i]["priority"] == 1:

        print("Priority Level : Emergency")

    elif patients[i]["priority"] == 2:

        print("Priority Level : Serious")

    else:

        print("Priority Level : Normal")

    print("---------------------------------------")

print("\nEmergency patients are treated first.")
