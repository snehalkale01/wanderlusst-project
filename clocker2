#include <iostream>
#include <string>
using namespace std;

int main()
{
    int choice;
    string plaintext;
    string ciphertext = "";
    int modFactor;

    do
    {
        // Menu
        cout << "\n===== MENU =====" << endl;
        cout << "1. Encrypt Text" << endl;
        cout << "2. Exit" << endl;
        cout << "Enter your choice: ";
        cin >> choice;
        cin.ignore();

        switch(choice)
        {
            case 1:
            {
                ciphertext = "";

                // Input plaintext
                cout << "\nEnter plaintext string: ";
                getline(cin, plaintext);

                // Input mod factor
                cout << "Enter mod factor: ";
                cin >> modFactor;
                cin.ignore();

                // Encryption using XOR Operator
                for(int i = 0; i < plaintext.length(); i++)
                {
                    char encryptedChar;

                    encryptedChar = plaintext[i] ^ modFactor;

                    ciphertext += encryptedChar;
                }

                // Display ciphertext
                cout << "\nCiphertext: ";

                for(int i = 0; i < ciphertext.length(); i++)
                {
                    cout << ciphertext[i];
                }

                cout << endl;

                break;
            }

            case 2:
                cout << "\nProgram Exited Successfully!" << endl;
                break;

            default:
                cout << "\nInvalid Choice!" << endl;
        }

    } while(choice != 2);

    return 0;
}





