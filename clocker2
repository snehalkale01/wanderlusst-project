#include<iostream>
#include<cstring>
using namespace std;

// ===== COLUMNAR TRANSPOSITION =====

void columnarEncrypt(char text[], int key[], int n, char cipher[])
{
    int len = strlen(text), rows = (len + n - 1) / n, k = 0;
    char mat[20][20];

    for(int i=0;i<rows;i++)
        for(int j=0;j<n;j++)
            mat[i][j] = (k < len) ? text[k++] : 'X';

    k = 0;

    for(int x=0;x<n;x++)
    {
        int col = key[x] - 1;

        for(int i=0;i<rows;i++)
            cipher[k++] = mat[i][col];
    }

    cipher[k] = '\0';
}

void columnarDecrypt(char cipher[], int key[], int n, char text[])
{
    int len = strlen(cipher), rows = len / n, k = 0;
    char mat[20][20];

    for(int x=0;x<n;x++)
    {
        int col = key[x] - 1;

        for(int i=0;i<rows;i++)
            mat[i][col] = cipher[k++];
    }

    k = 0;

    for(int i=0;i<rows;i++)
        for(int j=0;j<n;j++)
            text[k++] = mat[i][j];

    text[k] = '\0';
}

// ===== RAIL FENCE =====

void railEncrypt(char text[], int rails, char cipher[])
{
    int len = strlen(text), row = 0, k = 0;
    bool down = true;

    char rail[20][20];

    for(int i=0;i<rails;i++)
        for(int j=0;j<len;j++)
            rail[i][j] = '\n';

    for(int col=0;col<len;col++)
    {
        rail[row][col] = text[col];

        if(row == 0) down = true;
        else if(row == rails-1) down = false;

        row = down ? row+1 : row-1;
    }

    for(int i=0;i<rails;i++)
        for(int j=0;j<len;j++)
            if(rail[i][j] != '\n')
                cipher[k++] = rail[i][j];

    cipher[k] = '\0';
}

void railDecrypt(char cipher[], int rails, char text[])
{
    int len = strlen(cipher), row = 0, k = 0;
    bool down = true;

    char rail[20][20];

    for(int i=0;i<rails;i++)
        for(int j=0;j<len;j++)
            rail[i][j] = '\n';

    for(int col=0;col<len;col++)
    {
        rail[row][col] = '*';

        if(row == 0) down = true;
        else if(row == rails-1) down = false;

        row = down ? row+1 : row-1;
    }

    for(int i=0;i<rails;i++)
        for(int j=0;j<len;j++)
            if(rail[i][j] == '*')
                rail[i][j] = cipher[k++];

    row = 0;
    down = true;
    k = 0;

    for(int col=0;col<len;col++)
    {
        text[k++] = rail[row][col];

        if(row == 0) down = true;
        else if(row == rails-1) down = false;

        row = down ? row+1 : row-1;
    }

    text[k] = '\0';
}
int main()
{
    int ch, key[10], n, rails;
    char text[100], cipher[100], decrypt[100];

    cout<<"1. Columnar Transposition\n2. Rail Fence\n";
    cout<<"Enter choice: ";
    cin>>ch;
    cin.ignore();

    cout<<"Enter text: ";
    cin.getline(text,100);

    if(ch == 1)
    {
        cout<<"Enter key length: ";
        cin>>n;

        cout<<"Enter key permutation: ";
        for(int i=0;i<n;i++)
            cin>>key[i];

        columnarEncrypt(text,key,n,cipher);
        columnarDecrypt(cipher,key,n,decrypt);
    }

    else if(ch == 2)
    {
        cout<<"Enter number of rails: ";
        cin>>rails;

        railEncrypt(text,rails,cipher);
        railDecrypt(cipher,rails,decrypt);
    }

    else
    {
        cout<<"Invalid Choice";
        return 0;
    }

    cout<<"\nEncrypted Text: "<<cipher;
    cout<<"\nDecrypted Text: "<<decrypt;

    return 0;
}
