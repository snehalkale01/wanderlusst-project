#include<iostream>
using namespace std;

int P10[]={3,5,2,7,4,10,1,9,8,6};
int P8[]={6,3,7,4,8,5,10,9};
int IP[]={2,6,3,1,4,8,5,7};
int IP1[]={4,1,3,5,7,2,8,6};
int EP[]={4,1,2,3,2,3,4,1};

int S0[4][4]={
    {1,0,3,2},
    {3,2,1,0},
    {0,2,1,3},
    {3,1,3,2}
};

int S1[4][4]={
    {0,1,2,3},
    {2,0,1,3},
    {3,0,1,0},
    {2,1,0,3}
};

string permute(string s,int p[],int n){
    string r="";
    for(int i=0;i<n;i++) r+=s[p[i]-1];
    return r;
}

string shift(string s){
    return s.substr(1)+s[0];
}

string XOR(string a,string b){
    string r="";
    for(int i=0;i<a.size();i++)
        r+=(a[i]==b[i])?'0':'1';
    return r;
}

string SW(string s){
    return s.substr(4,4)+s.substr(0,4);
}

string sbox(string s){
    int r=(s[0]-'0')*2+(s[3]-'0');
    int c=(s[1]-'0')*2+(s[2]-'0');
    int a=S0[r][c];

    r=(s[4]-'0')*2+(s[7]-'0');
    c=(s[5]-'0')*2+(s[6]-'0');
    int b=S1[r][c];

    return string()+char(a/2+'0')+char(a%2+'0')
                  +char(b/2+'0')+char(b%2+'0');
}

string fk(string s,string k){
    string L=s.substr(0,4), R=s.substr(4,4);
    string t=XOR(permute(R,EP,8),k);
    return XOR(L,sbox(t))+R;
}

int main(){

    string key,pt;
    cout<<"Enter 10-bit key: ";
    cin>>key;

    cout<<"Enter 8-bit plaintext: ";
    cin>>pt;

    key=permute(key,P10,10);

    string L=shift(key.substr(0,5));
    string R=shift(key.substr(5,5));

    string K1=permute(L+R,P8,8);

    L=shift(L);
    R=shift(R);

    string K2=permute(L+R,P8,8);

    pt=permute(pt,IP,8);

    pt=fk(pt,K1);
    pt=SW(pt);
    pt=fk(pt,K2);

    string cipher=permute(pt,IP1,8);

    cout<<"\nEncrypted Text: "<<cipher<<endl;

    cipher=permute(cipher,IP,8);

    cipher=fk(cipher,K2);
    cipher=SW(cipher);
    cipher=fk(cipher,K1);

    string plain=permute(cipher,IP1,8);

    cout<<"Decrypted Text: "<<plain<<endl;

    return 0;
}



