#include <iostream>
#include <fstream>
#include <cmath>
using namespace std;

// Function to calculate gcd
int gcd(int a, int b) {
    if (b == 0) return a;
    return gcd(b, a % b);
}

// Function to find d (mod inverse)
int modInverse(int e, int phi) {
    for (int d = 1; d < phi; d++) {
        if ((d * e) % phi == 1)
            return d;
    }
    return -1;
}

// Power mod function
long long powerMod(long long base, long long exp, long long mod) {
    long long result = 1;
    while (exp > 0) {
        result = (result * base) % mod;
        exp--;
    }
    return result;
}

int main() {
    int p = 17, q = 11;   // small primes for demo
    int n = p * q;
    int phi = (p - 1) * (q - 1);

    int e = 3; // public key
    while (gcd(e, phi) != 1) e++;

    int d = modInverse(e, phi); // private key

    cout << "Public Key (e, n): (" << e << ", " << n << ")\n";
    cout << "Private Key (d, n): (" << d << ", " << n << ")\n";

    ifstream fin("input.txt");
    ofstream fout("encrypted.txt");
    ofstream fdec("decrypted.txt");

    char ch;

    // Encryption
    while (fin.get(ch)) {
        int m = int(ch);
        long long cipher = powerMod(m, e, n);
        fout << cipher << " ";
    }

    fin.close();
    fout.close();

    // Decryption
    ifstream fin2("encrypted.txt");
    long long cipher;

    while (fin2 >> cipher) {
        char decrypted = char(powerMod(cipher, d, n));
        fdec << decrypted;
    }

    fin2.close();
    fdec.close();

    cout << "Encryption and Decryption completed.\n";

    return 0;
}



