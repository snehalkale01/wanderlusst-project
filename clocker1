#include<iostream>
#include<vector>
#include<queue>
#include<algorithm>
#include<map>

using namespace std;

// ================= SELECTION SORT =================

void selectionSort(vector<int> &arr)
{
    int n = arr.size();

    for(int i = 0; i < n; i++)
    {
        int minIndex = i;

        // Find minimum element
        for(int j = i + 1; j < n; j++)
        {
            if(arr[j] < arr[minIndex])
            {
                minIndex = j;
            }
        }

        // Swap elements
        swap(arr[i], arr[minIndex]);
    }

    cout << "\nOptimal Sorted Array:\n";

    for(int x : arr)
    {
        cout << x << " ";
    }

    cout << endl;
}


// ================= JOB SCHEDULING =================

struct Job
{
    string id;
    int deadline;
    int profit;
};

bool compare(Job a, Job b)
{
    return a.profit > b.profit;
}

void jobScheduling()
{
    vector<Job> jobs =
    {
        {"J1", 2, 100},
        {"J2", 1, 50},
        {"J3", 2, 10},
        {"J4", 1, 20},
        {"J5", 3, 30}
    };

    // Sort by highest profit
    sort(jobs.begin(), jobs.end(), compare);

    int maxDeadline = 0;

    for(Job j : jobs)
    {
        maxDeadline = max(maxDeadline, j.deadline);
    }

    vector<bool> slot(maxDeadline, false);

    vector<string> result;

    int totalProfit = 0;

    for(Job j : jobs)
    {
        for(int i = j.deadline - 1; i >= 0; i--)
        {
            if(!slot[i])
            {
                slot[i] = true;
                result.push_back(j.id);
                totalProfit += j.profit;
                break;
            }
        }
    }

    cout << "\nOptimal Job Sequence:\n";

    for(string s : result)
    {
        cout << s << " ";
    }

    cout << "\nMaximum Profit: " << totalProfit << endl;
}


// ================= DIJKSTRA ALGORITHM =================

void printPath(map<char,char> &parent, char node)
{
    if(parent[node] == node)
    {
        cout << node;
        return;
    }

    printPath(parent, parent[node]);

    cout << " -> " << node;
}

void dijkstra()
{
    map<char, vector<pair<char,int>>> graph;

    graph['A'] = {{'B',4}, {'C',1}};
    graph['B'] = {{'D',2}, {'E',5}};
    graph['C'] = {{'B',2}, {'D',4}};
    graph['D'] = {{'E',1}};
    graph['E'] = {};

    map<char,int> distance;
    map<char,char> parent;

    // Initialize distances
    for(auto node : graph)
    {
        distance[node.first] = 9999;
    }

    distance['A'] = 0;
    parent['A'] = 'A';

    priority_queue<
        pair<int,char>,
        vector<pair<int,char>>,
        greater<pair<int,char>>
    > pq;

    pq.push({0,'A'});

    while(!pq.empty())
    {
        int currentDistance = pq.top().first;
        char currentNode = pq.top().second;

        pq.pop();

        for(auto neighbor : graph[currentNode])
        {
            char nextNode = neighbor.first;
            int weight = neighbor.second;

            int newDistance = currentDistance + weight;

            // Update shorter path
            if(newDistance < distance[nextNode])
            {
                distance[nextNode] = newDistance;

                parent[nextNode] = currentNode;

                pq.push({newDistance, nextNode});
            }
        }
    }

    cout << "\nOptimal Shortest Paths from Source A:\n";

    for(auto d : distance)
    {
        cout << "\nNode " << d.first << endl;

        cout << "Distance = " << d.second << endl;

        cout << "Path = ";

        printPath(parent, d.first);

        cout << endl;
    }
}


