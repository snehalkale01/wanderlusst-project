#include<iostream>
#include<vector>
#include<queue>
#include<algorithm>
using namespace std;

vector<vector<int>> adj;

bool dfs(int current, int dest, vector<bool> &visited, vector<int>& path){
    visited[current] = true;
    path.push_back(current);
    cout<<current<<" ";
    if(current == dest){
        return true;
    }

    for(int neighbor: adj[current]){
        if(!visited[neighbor]){
            if(dfs(neighbor, dest, visited, path)){
                return true;
            }
        }
    }

    path.pop_back(); // backtracking
    return false;
}

void bfs(int start, int dest, int v){
    vector<bool> visited(v, false);
    vector<int> parent(v, -1);
    queue<int> q;
    cout<<"BFS traversal: ";
    visited[start] = true;
    q.push(start);

    while(!q.empty()){
        int current = q.front();
        q.pop();
        cout<<current<<" ";
        if(current == dest) break;

        for(int neighbor: adj[current]){
            if(!visited[neighbor]){
                visited[neighbor] = true;
                parent[neighbor] = current;
                q.push(neighbor);
            }
        }
    }

    vector<int> path;

    int current = dest;
    while(current != -1){
        path.push_back(current);
        current = parent[current];
    }

    reverse(path.begin(), path.end());
    cout<<"Shortest Path: ";
    for(int node: path)
        cout<<node<<" ";
}

int main(){
    int V, E;
    cout<<"Enter number of vertices: ";
    cin>>V;

    cout<<"Enter number of edges: ";
    cin>>E;

    adj.resize(V);

    cout<<"Enter edges(u v): ";
    for(int i = 0; i < E; i++){
        int u, v;
        cin>>u>>v;

        adj[u].push_back(v);
        adj[v].push_back(u);
    }
     int start, dest;
    cout<<"Enter start: ";
    cin>>start;

    cout<<"Enter destination: ";
    cin>>dest;
    vector<bool> visited(V, false);
    vector<int> path;
    cout<<"DFS traversal: ";
    if(dfs(start, dest, visited, path)){
        cout<<"Path Exists: ";
        for(int node: path) 
            cout<<node<<" ";
    }
    cout<< endl;

    bfs(start, dest, V);

    return 0;
}


