#include<iostream>
using namespace std;

#define MAX 20
int board[MAX][MAX];

bool leftRow[MAX];
bool upperDiagonal[2*MAX];
bool lowerDiagonal[2*MAX];

int n;

void printBoard(){
    cout<<"\nSolution\n\n";

    for(int i = 0; i<n; i++){
        for(int j = 0; j<n; j++){
            if(board[i][j] == 1){
                cout<<"Q ";
            }else{
                cout<<"* ";
            }
        }
        cout<<endl;
    }
}

bool solve(int col){
    if(col>=n){
        return true;
    }

    for(int row = 0; row<n; row++){
        if(leftRow[row] == false && lowerDiagonal[col+row] == false && upperDiagonal[col-row+n-1] == false){
            board[row][col] = 1;

            leftRow[row] = true;
            lowerDiagonal[col+row] = true;
            upperDiagonal[col-row+n-1] = true;

            if(solve(col+1)) return true;

            //backtracking
            board[row][col] = 0;

            leftRow[row] = false;
            lowerDiagonal[col+row] = false;
            upperDiagonal[col-row+n-1] = false;

        }
    }
    return false;
}

int main(){

    cout<<"Enter number of queens(1-20): ";
    cin>>n;
     
    if(n<0 || n>MAX){
        cout << "Invalid input";
        return 0;
    }

    for(int i = 0; i<n; i++){
        for(int j = 0; j<n; j++){
            board[i][j] = 0;
        }
    }

    for(int i =0; i<MAX; i++){
        leftRow[i] = false;
    }

    for(int i = 0; i< 2*MAX; i++){
        upperDiagonal[i] = false;
        lowerDiagonal[i] = false;
    }

    if(solve(0)){
        printBoard();
    }else{
        cout<<"No solution exists!\n";
    }


    return 0;
}


